# Copy to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored — never commit real values.

aws_region    = "us-east-1"
instance_name = "openclaw-vaniam"
lb_name       = "openclaw-lb"
domain_name   = "vaniam-ai.avenera.ai"
gateway_port  = 18789
iam_user_name   = "openclaw-bedrock"
iam_policy_name = "openclaw-bedrock-policy"

# Two-phase SSL attach. Keep false on the first apply.
# After adding the CNAME validation records and AWS shows the cert as VALID,
# change to true and re-run: terraform apply
attach_certificate = false
